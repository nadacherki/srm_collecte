#!/usr/bin/env sh
set -eu

needs_validation=0
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    needs_validation=1
  fi
done

if [ "$needs_validation" -ne 1 ]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File tools/validate_mobile_release.ps1
elif command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File tools/validate_mobile_release.ps1
else
  echo "pre-push: PowerShell introuvable; impossible de valider le push main." >&2
  exit 1
fi
