# Copier ce fichier en `.env` et remplir les valeurs. NE PAS commit `.env`.
# Toutes les variables sont lues par pprcollecte/settings.py au demarrage.

# ============================================================
# DJANGO CORE
# ============================================================
# Generer avec : python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# False en prod, True en dev local uniquement
DJANGO_DEBUG=True

# Liste comma-separated des hosts autorises. Pas de wildcard.
# En dev : 127.0.0.1,localhost,10.0.2.2  (10.0.2.2 = emulateur Android)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,10.0.2.2

# ============================================================
# BASE DE DONNEES POSTGRES + POSTGIS
# ============================================================
DB_NAME=SRM_bureau
DB_USER=postgres
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CLIENT_ENCODING=UTF8

# ============================================================
# JWT (a configurer une fois simplejwt installe)
# ============================================================
# Duree de vie des tokens (en minutes / jours)
JWT_ACCESS_LIFETIME_MINUTES=15
JWT_REFRESH_LIFETIME_DAYS=7

# ============================================================
# CACHE / RATE-LIMIT (Redis) — REQUIS EN PROD
# ============================================================
# Sans REDIS_URL, le boot echoue si DJANGO_DEBUG=False (le throttle
# login serait inefficace en multi-worker gunicorn).
REDIS_URL=redis://redis:6379/1

# ============================================================
# REMONTEE D'ERREURS
# ============================================================
# Sentry (recommande). Vide = desactive.
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_RELEASE=
# Mail ADMINS : "Nom1:mail1,Nom2:mail2"
DJANGO_ADMINS=
DJANGO_SERVER_EMAIL=srm-collecte@localhost
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# ============================================================
# DEPLOIEMENT (docker-compose / Caddy / gunicorn)
# ============================================================
# Domaine prod pour le certificat TLS auto Let's Encrypt (Caddy).
SRM_DOMAIN=
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

# ============================================================
# BASEMAP
# ============================================================
BASEMAP_PMTILES_CLI_PATH=
BASEMAP_BUILD_PMTILES_SOURCE_URL=
BASEMAP_BUILD_PMTILES_SOURCE_NAME=
BASEMAP_BUILD_PMTILES_ATTRIBUTION=
