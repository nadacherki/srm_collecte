<?xml version="1.0" encoding="utf-8"?>
<!--
    Politique reseau du build RELEASE : HTTP cleartext INTERDIT, partout,
    sans exception. Seuls les certificats systeme sont acceptes.

    Le build DEBUG utilise une version permissive de ce meme fichier
    (src/debug/res/xml/network_security_config.xml) qui autorise le
    cleartext vers l'emulateur/localhost pour le developpement. Le
    resource merger Android substitue automatiquement la variante debug
    lors d'un build debug ; le release garde CE fichier strict.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
